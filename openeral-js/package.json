{
  "name": "openeral-js",
  "version": "0.1.0",
  "description": "PostgreSQL-backed virtual filesystem for AI agents via just-bash",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openeral": "dist/bin/openeral.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node lint.mjs",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "just-bash": "^2.14.0",
    "pg": "^8.13.0"
  },
  "optionalDependencies": {
    "pg-embed": "^0.7.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
